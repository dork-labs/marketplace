          "required": [
            "mergeOnApproval",
            "requireCiGreen",
            "teardownWorktree",
            "onConflict",
            "ciRetries",
            "reapproveOnFunctionalChange",
            "maxMergeAttempts"
          ],
          "additionalProperties": false
        },
        "circuitBreaker": {
          "type": "object",
          "properties": {
            "estimateMultiplier": {
              "default": 2,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "tokenBudget": {
              "default": 2000000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["estimateMultiplier", "tokenBudget"],
          "additionalProperties": false
        }
      },
      "required": ["planApproval", "review", "circuitBreaker"],
      "additionalProperties": false
