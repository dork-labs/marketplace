              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "stateCategory": {
              "type": "string",
              "enum": ["backlog", "unstarted", "started", "completed", "canceled"]
            },
            "humanGate": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "review": {
          "default": {
            "stateCategory": "started",
