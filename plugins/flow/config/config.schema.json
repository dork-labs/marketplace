              "maximum": 9007199254740991
            },
            "intervalMs": {
              "default": 300000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["enabled", "priority", "intervalMs"],
          "additionalProperties": false
        },
        "dispatch": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "priority": {
              "default": 30,
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "intervalMs": {
              "default": 300000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["enabled", "priority", "intervalMs"],
          "additionalProperties": false
        },
        "triage": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
