        "marker": {
          "default": "— 🤖 /flow",
          "type": "string"
        }
      },
      "required": ["agent", "reviewer", "marker"],
      "additionalProperties": false
    },
    "ownership": {
      "type": "object",
      "properties": {
        "claimAssignedToAgent": {
          "default": true,
          "type": "boolean"
        },
        "claimUnassigned": {
          "default": true,
          "type": "boolean"
        },
        "claimAssignedToHuman": {
          "default": false,
          "type": "boolean"
        },
        "claimAssignedToOthers": {
          "default": false,
          "type": "boolean"
        },
        "scope": {
          "default": ["issues", "projects"],
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["issues", "projects"]
          }
        }
      },
      "required": [
        "claimAssignedToAgent",
        "claimUnassigned",
        "claimAssignedToHuman",
        "claimAssignedToOthers",
        "scope"
