            "priority": {
              "default": 40,
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "intervalMs": {
              "default": 3600000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["enabled", "priority", "intervalMs"],
          "additionalProperties": false
        },
        "hygiene": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "priority": {
              "default": 50,
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "intervalMs": {
              "default": 21600000,
              "type": "integer",
              "exclusiveMinimum": 0,
