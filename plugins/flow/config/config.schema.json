        "done": {
          "default": {
            "command": "/flow:done",
            "label": "stage/done",
            "stateCategory": "completed"
          },
          "type": "object",
          "properties": {
            "command": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "stateCategory": {
              "type": "string",
              "enum": ["backlog", "unstarted", "started", "completed", "canceled"]
            },
            "humanGate": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
