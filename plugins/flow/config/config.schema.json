        "nudge": {
          "type": "object",
          "properties": {
            "relay": {
              "default": false,
              "type": "boolean"
            },
            "telegram": {
              "default": false,
              "type": "boolean"
            }
          },
          "required": ["relay", "telegram"],
          "additionalProperties": false
        }
      },
      "required": ["comms", "calibration", "nudge"],
      "additionalProperties": false
