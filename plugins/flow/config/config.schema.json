    "involvement": {
      "type": "object",
      "properties": {
        "comms": {
          "default": "infer-from-trigger",
          "type": "string",
          "enum": ["infer-from-trigger", "concise", "verbose"]
        },
        "calibration": {
          "type": "object",
          "properties": {
            "proceedSilentlyWhen": {
              "default": ["reversible", "confident"],
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["reversible", "confident"]
              }
            },
            "alwaysAsk": {
              "default": [
                "irreversible-or-destructive",
                "outward-facing",
                "secrets-or-spend",
                "scope-change"
              ],
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "irreversible-or-destructive",
                  "outward-facing",
                  "secrets-or-spend",
                  "scope-change"
                ]
              }
            },
            "stageBias": {
              "type": "object",
              "properties": {
                "intake": {
                  "default": "ask",
                  "type": "string",
                  "enum": ["ask", "proceed-and-log"]
                },
                "execution": {
                  "default": "proceed-and-log",
                  "type": "string",
                  "enum": ["ask", "proceed-and-log"]
                }
              },
              "required": ["intake", "execution"],
              "additionalProperties": false
            },
            "assumptionLog": {
              "type": "object",
              "properties": {
                "artifact": {
                  "default": true,
                  "type": "boolean"
                },
                "ticketComment": {
                  "default": "pm-driven",
                  "type": "string",
                  "enum": ["pm-driven", "always", "never"]
