        "stageBudgets": {
          "type": "object",
          "properties": {
            "specify": {
              "default": 40000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "decompose": {
              "default": 40000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "execute": {
              "default": 80000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "verify": {
              "default": 40000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "review": {
              "default": 30000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["specify", "decompose", "execute", "verify", "review"],
          "additionalProperties": false
