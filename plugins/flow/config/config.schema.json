            "teardownWorktree": {
              "default": true,
              "type": "boolean"
            },
            "onConflict": {
              "default": "resolve-if-mechanical",
              "type": "string",
              "enum": ["resolve-if-mechanical", "always-bounce", "never-resolve"]
            },
            "ciRetries": {
              "default": 1,
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
