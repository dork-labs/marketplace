    "autonomy": {
      "type": "object",
      "properties": {
        "default": {
          "default": "auto",
          "type": "string",
          "enum": ["auto", "manual"]
        },
        "concurrency": {
          "default": "sequential",
          "type": "string",
          "enum": ["sequential", "parallel"]
        },
        "wipCap": {
          "type": "object",
          "properties": {
            "global": {
              "default": 2,
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "perProject": {
              "default": 1,
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["global", "perProject"],
          "additionalProperties": false
        },
        "seat": {
          "default": "pulse",
          "type": "string",
          "enum": ["pulse"]
        }
      },
      "required": ["default", "concurrency", "wipCap", "seat"],
      "additionalProperties": false
    },
    "loops": {
